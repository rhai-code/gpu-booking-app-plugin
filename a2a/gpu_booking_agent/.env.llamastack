# Llama Stack configuration (self-hosted, proxied through Llama Stack)
# Uses the OpenAI-compatible endpoint from Llama Stack on the cluster
# Gemini models are recommended over vLLM for reliable tool calling.

ADK_MODEL=openai/gemini/models/gemini-2.5-flash
OPENAI_API_BASE=https://<llamastack-route>/v1
OPENAI_API_KEY=not-needed

# MCP tool server URL (in-cluster service)
MCP_URL=http://gpu-booking-tool:8080/mcp

# A2A server settings
HOST=0.0.0.0
PORT=8001
