# Ollama / vLLM configuration for local or self-hosted LLMs
# ADK supports OpenAI-compatible endpoints via LiteLLM

# Use an OpenAI-compatible model string
# For Ollama: "ollama_chat/llama3.1" or "ollama_chat/mistral"
# For vLLM: "openai/model-name" with OPENAI_API_BASE set
ADK_MODEL=ollama_chat/llama3.1

# Ollama endpoint (default Ollama port)
OPENAI_API_BASE=http://localhost:11434

# No API key needed for local Ollama
OPENAI_API_KEY=not-needed

# MCP tool server URL
MCP_URL=http://localhost:8000/mcp

# A2A server settings
HOST=0.0.0.0
PORT=8001
