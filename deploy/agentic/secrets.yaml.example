# LLM API key secret -- choose ONE provider configuration
#
# Option A: Google Gemini (direct)
#   Set GOOGLE_API_KEY only
#
# Option B: Llama Stack / OpenAI-compatible endpoint
#   Set OPENAI_API_BASE and OPENAI_API_KEY
#   Set ADK_MODEL in the agent deployment to: openai/<model-name>

apiVersion: v1
kind: Secret
metadata:
  name: llm-api-key
type: Opaque
stringData:
  # Option A: Google Gemini
  GOOGLE_API_KEY: "<your-google-api-key>"

  # Option B: Llama Stack / OpenAI-compatible
  # OPENAI_API_BASE: "https://<llamastack-route>/v1"
  # OPENAI_API_KEY: "dummy"
